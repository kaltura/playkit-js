{
  "repository": "kaltura/playkit-js",
  "version": "1.0.0",
  "lastUpdated": "2026-04-28",
  "coreResponsibility": {
    "summary": "PlayKit JS is the core HTML5 video playback engine for the Kaltura Player ecosystem, providing a unified interface for adaptive streaming, DRM protection, track management, and extensible plugin architecture.",
    "type": "core-playback-engine"
  },
  "domainAndLogicOwnership": {
    "featureOwnership": [
      "HTML5 video playback lifecycle management",
      "MediaSource Extensions (MSE) integration",
      "Encrypted Media Extensions (EME) / DRM handling (Widevine, PlayReady, FairPlay)",
      "Adaptive bitrate streaming (ABR) control and track selection",
      "Multi-track management (video, audio, text/captions, image/thumbnails)",
      "Player state machine (idle, loading, playing, paused, buffering)",
      "Text track display and styling (VTT, TTML captions)",
      "Fullscreen and Picture-in-Picture control",
      "Timed metadata parsing and events",
      "External captions handler",
      "Thumbnail/image track support",
      "Playback middleware pipeline for plugin intercepts",
      "Engine decorator pattern for extending playback behavior",
      "Autoplay detection and fallback handling"
    ],
    "dataHandling": [
      "PKSourcesConfigObject: Media source configuration (HLS, DASH, progressive)",
      "Player state machine transitions (StateType: idle, loading, playing, paused, buffering)",
      "Track objects (VideoTrack, AudioTrack, PKTextTrack, ImageTrack)",
      "DRM data objects (PKDrmDataObject, PKDrmConfigObject)",
      "Media source adapters registration and selection",
      "Playback attributes state (volume, muted, playbackRate, currentTime)",
      "Text style configuration (TextStyle)",
      "Thumbnail info (ThumbnailInfo)",
      "Timed metadata (TimedMetadata)",
      "Player capabilities and environment detection (Env)",
      "Error objects with severity, category, and code classification"
    ]
  },
  "integrationPoints": {
    "upstream": [
      "kaltura/kaltura-player-js: Main player wrapper that provides configuration, plugins, and Kaltura backend integration",
      "kaltura/playkit-js-providers: Backend data providers for Kaltura OVP/OTT",
      "Media source adapters (hls.js, shaka-player via external adapter packages)"
    ],
    "downstream": [
      "kaltura/playkit-js-ui: UI layer consuming player events and state",
      "kaltura/playkit-js-hls: HLS.js adapter for HLS streaming",
      "kaltura/playkit-js-dash: Shaka Player adapter for DASH streaming",
      "kaltura/playkit-js-ima: Google IMA SDK integration for ads",
      "kaltura/playkit-js-kava: Kaltura analytics plugin",
      "kaltura/playkit-js-youbora: NPAW/Youbora analytics integration",
      "kaltura/playkit-js-cast-sender: Chromecast sender integration",
      "kaltura/playkit-js-bumper: Bumper/interstitial plugin",
      "kaltura/playkit-js-vr: VR/360 video support plugin"
    ],
    "externalAPIs": [
      "Native HTML5 Video Element API",
      "MediaSource Extensions (MSE) API",
      "Encrypted Media Extensions (EME) API",
      "Fullscreen API",
      "Picture-in-Picture API",
      "WebVTT / TTML caption parsing",
      "ua-parser-js: Browser/device detection"
    ]
  },
